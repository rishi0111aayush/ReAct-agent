GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Google OAuth — https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Session signing secret — python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret

# Redis — optional locally, required on Render for caching + memory
# Leave blank to run without Redis (caching/memory silently disabled)
REDIS_URL=redis://localhost:6379
RATE_LIMIT_RPM=30
